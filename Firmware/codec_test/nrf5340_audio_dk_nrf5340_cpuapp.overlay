&{/} {
    leds {
        compatible = "gpio-leds";

        rgb1_red: led_0 {
			gpios = <&gpio0 7 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "0 LED_RGB_RED";
		};

		rgb1_green: led_1 {
			gpios = <&gpio0 25 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "0 LED_RGB_GREEN";
		};

		rgb1_blue: led_2 {
			gpios = <&gpio0 26 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "0 LED_RGB_BLUE";
		};

		rgb2_red: led_3 {
			gpios = <&gpio0 28 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "1 LED_RGB_RED";
		};

		rgb2_green: led_4 {
			gpios = <&gpio0 29 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "1 LED_RGB_GREEN";
		};

		rgb2_blue: led_5 {
			gpios = <&gpio0 30 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "1 LED_RGB_BLUE";
		};

		led1_blue: led_6 {
			gpios = <&gpio0 31 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "2 LED_MONO_BLUE";
		};

		led2_green: led_7 {
			gpios = <&gpio1 0 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "3 LED_MONO_GREEN";
		};

		led3_green: led_8 {
			gpios = <&gpio1 1 (GPIO_ACTIVE_LOW | GPIO_OPEN_DRAIN)>;
			label = "4 LED_MONO_GREEN";
		};
    };
};

&i2c2 {
    status = "okay";
    pinctrl-0 = <&i2c2_default>;
    pinctrl-1 = <&i2c2_sleep>;
    pinctrl-names = "default", "sleep";
};

&i2c1 {
    status = "okay";
    pinctrl-0 = <&i2c1_default>;
    pinctrl-1 = <&i2c1_sleep>;
    pinctrl-names = "default", "sleep";
};

&clock {
	hfclkaudio-frequency = <12288000>;
};

&i2s0 {
	compatible = "nordic,nrf-i2s";
	status = "okay";
	pinctrl-0 = <&i2s0_default>;
	pinctrl-1 = <&i2s0_sleep>;
	pinctrl-names = "default", "sleep";
	clock-source = "ACLK";
};

&pinctrl {
    i2c1_default: i2c1_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 1, 3)>,
                    <NRF_PSEL(TWIM_SDA, 1, 2)>;
        };
    };

    i2c1_sleep: i2c1_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 1, 3)>,
                    <NRF_PSEL(TWIM_SDA, 1, 2)>;
        };
    };

	i2c2_default: i2c2_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 0, 24)>, <NRF_PSEL(TWIM_SDA, 0, 23)>;
        };
    };

    i2c2_sleep: i2c2_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SCL, 0, 24)>, <NRF_PSEL(TWIM_SDA, 0, 23)>;
        };
    };

	i2s0_default: i2s0_default {
		group1 {
			psels = <NRF_PSEL(I2S_SCK_M, 0, 14)>,
				<NRF_PSEL(I2S_LRCK_M, 0, 16)>,
				<NRF_PSEL(I2S_SDOUT, 0, 13)>,
				<NRF_PSEL(I2S_SDIN, 0, 15)>;
		};
	};

	i2s0_sleep: i2s0_sleep {
		group1 {
			psels = <NRF_PSEL(I2S_SCK_M, 0, 14)>,
				<NRF_PSEL(I2S_LRCK_M, 0, 16)>,
				<NRF_PSEL(I2S_SDOUT, 0, 13)>,
				<NRF_PSEL(I2S_SDIN, 0, 15)>;
			low-power-enable;
		};
	};
};
