			label = "Blue LED 1";        /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:37 */
		};
	};

	/* node '/buttons' defined in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:41 */
	buttons {
		compatible = "gpio-keys"; /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:42 */

		/* node '/buttons/button_0' defined in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:43 */
		button0: button_0 {
