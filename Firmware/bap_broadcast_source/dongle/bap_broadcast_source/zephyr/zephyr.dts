	/* node '/clocks' defined in zephyr\dts\arm\nordic\nrf52820.dtsi:38 */
	clocks {

		/* node '/clocks/hfxo' defined in zephyr\dts\arm\nordic\nrf52820.dtsi:39 */
		hfxo: hfxo {
			compatible = "nordic,nrf52-hfxo"; /* in zephyr\dts\arm\nordic\nrf52820.dtsi:40 */
			clock-frequency = < 0x3d09000 >;  /* in zephyr\dts\arm\nordic\nrf52820.dtsi:41 */
			startup-time-us = < 0x578 >;      /* in zephyr\dts\arm\nordic\nrf52820.dtsi:42 */
			#clock-cells = < 0x0 >;           /* in zephyr\dts\arm\nordic\nrf52820.dtsi:43 */
		};
	};

	/* node '/leds' defined in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:21 */
	leds {
		compatible = "gpio-leds"; /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:22 */

		/* node '/leds/led_0' defined in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:23 */
		led0_green: led_0 {
			gpios = < &gpio0 0xf 0x1 >; /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:24 */
			label = "Green LED 0";      /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:25 */
		};

		/* node '/leds/led_1' defined in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:27 */
		led1_red: led_1 {
			gpios = < &gpio0 0x14 0x1 >; /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:28 */
			label = "Red LED 1";         /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:29 */
		};

		/* node '/leds/led_2' defined in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:31 */
		led1_green: led_2 {
			gpios = < &gpio0 0x1c 0x1 >; /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:32 */
			label = "Green LED 1";       /* in nrf\boards\nordic\nrf52820dongle\nrf52820dongle_nrf52820.dts:33 */
