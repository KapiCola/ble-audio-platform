	/* node '/cpus' defined in zephyr\dts\arm\nordic\nrf52820.dtsi:19 */
	cpus {
		#address-cells = < 0x1 >; /* in zephyr\dts\arm\nordic\nrf52820.dtsi:20 */
		#size-cells = < 0x0 >;    /* in zephyr\dts\arm\nordic\nrf52820.dtsi:21 */

		/* node '/cpus/cpu@0' defined in zephyr\dts\arm\nordic\nrf52820.dtsi:23 */
		cpu@0 {
			device_type = "cpu";          /* in zephyr\dts\arm\nordic\nrf52820.dtsi:24 */
			compatible = "arm,cortex-m4"; /* in zephyr\dts\arm\nordic\nrf52820.dtsi:25 */
			reg = < 0x0 >;                /* in zephyr\dts\arm\nordic\nrf52820.dtsi:26 */
			#address-cells = < 0x1 >;     /* in zephyr\dts\arm\nordic\nrf52820.dtsi:27 */
