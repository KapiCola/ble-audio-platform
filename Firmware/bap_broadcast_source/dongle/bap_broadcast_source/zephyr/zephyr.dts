	/* node '/usb_audio2' defined in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:10 */
	uac2_broadcaster: usb_audio2 {
		compatible = "zephyr,uac2"; /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:11 */
		status = "okay";            /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:12 */
		full-speed;                 /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:13 */
		audio-function = < 0xff >;  /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:14 */

		/* node '/usb_audio2/aclk' defined in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:20 */
		uac_aclk: aclk {
			compatible = "zephyr,uac2-clock-source"; /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:21 */
			clock-type = "internal-programmable";    /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:22 */
			frequency-control = "read-only";         /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:23 */
			sampling-frequencies = < 0xbb80 >;       /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:24 */
			sof-synchronized;                        /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:28 */
			phandle = < 0x7 >;                       /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:34 */
		};

		/* node '/usb_audio2/out_terminal' defined in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:32 */
		out_terminal: out_terminal {
			compatible = "zephyr,uac2-input-terminal"; /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:33 */
			clock-source = < &uac_aclk >;              /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:34 */
			terminal-type = < 0x101 >;                 /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:35 */
			front-left;                                /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:36 */
			front-right;                               /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:37 */
			phandle = < 0x8 >;                         /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:43 */
		};

		/* node '/usb_audio2/headphones' defined in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:41 */
		broadcaster_output: headphones {
			compatible = "zephyr,uac2-output-terminal"; /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:42 */
			data-source = < &out_terminal >;            /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:43 */
			clock-source = < &uac_aclk >;               /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:44 */
			terminal-type = < 0x300 >;                  /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:45 */
		};

		/* node '/usb_audio2/out_interface' defined in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:48 */
		as_iso_out: out_interface {
			compatible = "zephyr,uac2-audio-streaming"; /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:49 */
			linked-terminal = < &out_terminal >;        /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:50 */
			subslot-size = < 0x2 >;                     /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:51 */
			bit-resolution = < 0x10 >;                  /* in D:/Inzynierka_V2/Kody_testowe/bap_broadcast_source/app.overlay:52 */
		};
	};
};
